# Database Configuration (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database

# JWT Configuration - CRITICAL FOR PRODUCTION
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Port
PORT=5000

# Environment
NODE_ENV=development

# Note: For Vercel deployment, ensure the following:
# 1. DATABASE_URL is set in Vercel Environment Variables
# 2. JWT_SECRET is set in Vercel Environment Variables (use a strong random string)
# 3. NODE_ENV should be set to 'production' in Vercel
